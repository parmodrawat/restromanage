# Enable Rewrite Engine
RewriteEngine On

# Redirect to login if accessing root without session
RewriteCond %{REQUEST_URI} ^/restro/?$
RewriteRule ^(.*)$ /restro/auth/login.html [L]

# Allow access to auth pages
RewriteCond %{REQUEST_URI} ^/restro/auth/
RewriteRule ^(.*)$ - [L]

# Allow access to assets
RewriteCond %{REQUEST_URI} ^/restro/assets/
RewriteRule ^(.*)$ - [L]

# Allow access to images
RewriteCond %{REQUEST_URI} ^/restro/img/
RewriteRule ^(.*)$ - [L]

# Prevent directory listing
Options -Indexes

# Custom error pages (optional)
# ErrorDocument 404 /restro/auth/login.html
